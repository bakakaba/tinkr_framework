{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "include-component-in-tag": false,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "packages": {
    ".": {
      "extra-files": [
        {
          "type": "toml",
          "path": "Cargo.toml",
          "jsonpath": "$.workspace.package.version"
        },
        {
          "type": "toml",
          "path": "crates/tinkr_framework/Cargo.toml",
          "jsonpath": "$.dependencies.tinkr_config.version"
        },
        {
          "type": "toml",
          "path": "crates/tinkr_config/Cargo.toml",
          "jsonpath": "$.dependencies.tinkr_config_macros.version"
        },
        {
          "type": "toml",
          "path": "Cargo.lock",
          "jsonpath": "$.package[?(@.name.value=='tinkr_framework'||@.name.value=='tinkr_config'||@.name.value=='tinkr_config_macros'||@.name.value=='demo')].version"
        }
      ]
    }
  }
}
